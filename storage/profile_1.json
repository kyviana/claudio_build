  "ingame_hotkeys": "-- ===== LIDER =====\nlocal _lastSentId = nil\n\nmacro(500, \"Combo Leader - Enviar\", function()\n    if not storage.isLeader then return end\n    local target = g_game.getAttackingCreature()\n    if target then\n        local id = target:getId()\n        if id ~= _lastSentId then\n            talkChannel(1, \"!cl \" .. id)\n            _lastSentId = id\n        end\n    else\n        if _lastSentId ~= nil then\n            talkChannel(1, \"!cl stop\")\n            _lastSentId = nil\n        end\n    end\nend)\n\nUI.Button(\"Sou o Lider\", function()\n    storage.isLeader = not storage.isLeader\n    warn(storage.isLeader and \"Lider ON\" or \"Lider OFF\")\nend)",
