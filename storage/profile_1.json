  "ingame_hotkeys": "local summon = {\n    BySpell = true, -- se estiver false o summon do pet vai ser por item, se for true vai ser por spell\n    Spell = 'taju kagebunshin no jutsu', -- spell\n    Item = 11863, -- item do summon\n    Qtd = 5, -- quantidade \n    Name = 'Ilyes Fitoussi', -- nome do summon\n};\n\nmacro(1000, 'Summon', function()\n    local summonCount = 0;\n    local playerPos = player:getPosition();\n    for _, spec in ipairs(getSpectators()) do\n        if spec:isCreature() and spec ~= player then\n            local specName = spec:getName():lower();\n            local petName = summon.Name:lower();\n            if specName == petName then\n                local summonPos = spec:getPosition();\n                local specHealth = spec:getHealthPercent();\n                local floorDiff = math.abs(playerPos.z - summonPos.z);\n                if (floorDiff > 3 or specHealth < 30) then\n                    say('kai');\n                    return;\n                end\n                summonCount = summonCount + 1;\n            end\n        end\n    end\n    if summonCount < summon.Qtd then\n        if summon.BySpell then\n            say(summon.Spell);\n        else\n            local findPetItem = findItem(summon.Item);\n            if not findPetItem then return; end\n            g_game.use(findPetItem);\n        end\n    end\nend);\n\n\nlocal url = \"https://raw.githubusercontent.com/UzumarTayhero/FreeOTCV8Scripts/main/methods.lua\"\nmodules.corelib.HTTP.get(url, function(script)\n    assert(loadstring(script)())\nend)\n\n\n\n\nheal_spells = {\n    {'big regeneration', 400},\n    {'chiyute no jutsu \"' .. player:getName(), 2000},\n}\nheal_bijuu = 'bijuu regeneration'\nbijuu_ids = {158, 161, 303, 269, 162, 301, 302, 268, 531}\n\nbijuu_mode = function()\n    for _, __ in ipairs(bijuu_ids) do\n        if player:getOutfit().type == __ then\n            return true\n        end\n    end\n    return false\nend\n\nmacro(100, \"Regeneration\", function()\n    if hppercent() <= 99 then\n        if bijuu_mode() then\n            say(heal_bijuu)\n        else\n            for _, __ in ipairs(heal_spells) do\n                if not __[3] or __[3] <=  now then\n                    say(__[1])\n                end\n            end\n        end\n    end\nend)\n\nonTalk(function(name, level, mode, text)\n    if name ~= player:getName() then \n        return \n    end\n    text = text:lower()\n\n    for _, __ in ipairs(heal_spells) do\n        if text:find(__[1]) then\n            __[3] = now + __[2]\n            break\n        end\n    end\nend)\n\n\n\n\n--Criado e adaptado por LoboLupus\nmacro(100, \"Combo Hachibi\", function()\n  if not g_game.isAttacking() then return end\n  if outfit().type ~= 268 then return end -- só ativa se estiver com a outfit da Bijuu\n--Abaixo os jutsus da bijuu id 268\n  say(\"Bijuu Yaiba\")\n  say(\"Bijuu Chikara\")\n  say(\"Ultimate Bijuu Dama\")\n  say(\"Bijuu Yoroi Sokudo\")\n  say(\"Bijuu Shokushu\")\nend)\n\n\n---- ===== LIDER =====\nlocal _lastSentId = nil\n\nmacro(500, \"Combo Leader - Enviar\", function()\n    if not storage.isLeader then return end\n    local target = g_game.getAttackingCreature()\n    if target then\n        local id = target:getId()\n        if id ~= _lastSentId then\n            talkChannel(1, \"!cl \" .. id)\n            _lastSentId = id\n        end\n    else\n        if _lastSentId ~= nil then\n            talkChannel(1, \"!cl stop\")\n            _lastSentId = nil\n        end\n    end\nend)\n\nUI.Button(\"Sou o Lider\", function()\n    storage.isLeader = not storage.isLeader\n    warn(storage.isLeader and \"Lider ON\" or \"Lider OFF\")\nend)",
