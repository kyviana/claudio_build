  "ingame_hotkeys2": "macro(100, \"Combo Tobirama\", function()\n    if g_game.isAttacking() then\n        say(\"suiton suiryudan no jutsu\")\n        say(\"suiton tenkyu\")\n        say(\"suiton goshokuzame\")\n        say(\"suiton teppodama\")\n        say(\"suiton bakusui shouha\")\n        say(\"daibakufu no jutsu\")\n        say(\"suiton suishoha\")\n        say(\"suiton suijinheki no jutsu\")\n    end\nend)\n\nmacro(100, \"Combo Shisui\", function()\n    if now < SGO then return end\n    if g_game.isAttacking() then\n        say(\"katon karyu endan\")\n        say(\"fuumetsu shuriken\")\n        say(\"katon endan\")\n        say(\"susanoo tsukumo\")\n        say(\"katon daibakuha\")\n        say(\"susanoo danmaku\")\n    end\nend)\n\n\nmacro(100, \"Leee\", function()\n    if g_game.isAttacking() then\n        say(\"ura renge\")\n        say(\"konoha daisenpu\")\n        say(\"kougeki\")\n        say(\"furi renge\")\n        say(\"konoha daigouken\")\n    end\nend)\n\n\nmacro(100, \"Combo Madara\", function()\n    if g_game.isAttacking() then\n        say(\"shin tengai shinsei\")\n        say(\"tengai yasaka no magatama\")\n        say(\"tengai shinsei\")\n        say(\"susano attack\")\n        say(\"mokuton mosayko no jutsu\")\n        say(\"katon endan\")\n        say(\"suiton suijinheki no jutsu\")\n        say(\"katon booru kaki\")\n    end\nend)\n\n\n\n\nmacro(100, \"Combo Kurenai\", function()\n    if now < SGO then return end\n    if g_game.isAttacking() then\n        say(\"sansai no jutsu\")\n        say(\"magen hiei no jutsu\")\n        say(\"botanyuki\")\n        say(\"magen hanagasumi\")\n        say(\"anshousui\")\n        say(\"magen jubaku satsu\")\n        say(\"kaki buyou\")\n  end\n  end)\n\nmacro(100, \"Combo Minato\", function()\n    if g_game.isAttacking() then\n        say(\"taikyoku hiraishin rasengan\")\n        say(\"hiraishin ninodan\")\n        say(\"taikyoku rasengan\")\n        say(\"flash rasengan\")\n        say(\"dai taikyoku rasengan\")\n        say(\"fuuton rasenshuriken\")\n    end\nend)\n\nmacro(1000, \"Area Madara\", function()\n    if now < SGO then return end\n    say(\"fuuton sohenka no jutsu\")\nend)",
